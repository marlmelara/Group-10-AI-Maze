\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Left: maze-beta walls + hazards. Right: agent's trajectory on a successful evaluation episode. The single-entry chute from $(2,32)$ up to the goal at $(0,31)$ is visible in the top-centre.}}{8}{figure.caption.10}\protected@file@percent }
\newlabel{fig:beta}{{5}{8}{Left: maze-beta walls + hazards. Right: agent's trajectory on a successful evaluation episode. The single-entry chute from $(2,32)$ up to the goal at $(0,31)$ is visible in the top-centre}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Solution dashboard (novel visualization). Top row: maze-alpha map, trajectory, and final-evaluation metrics panel. Bottom row: maze-beta map, trajectory, and combined convergence plot showing turns-to-goal dropping across 5 evaluation episodes for both mazes on a log-scale y-axis. A single image that tells the full story of the agent's behavior on both mazes.}}{9}{figure.caption.11}\protected@file@percent }
\newlabel{fig:dashboard}{{6}{9}{Solution dashboard (novel visualization). Top row: maze-alpha map, trajectory, and final-evaluation metrics panel. Bottom row: maze-beta map, trajectory, and combined convergence plot showing turns-to-goal dropping across 5 evaluation episodes for both mazes on a log-scale y-axis. A single image that tells the full story of the agent's behavior on both mazes}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Visual progression on maze-beta (no training). \emph  {Top row:} episode~1 --- 5203 turns, 49 deaths spent discovering the V-fire rotations and the single-entry chute to the exit. \emph  {Bottom row:} converged episode~3 --- the agent runs the 80-turn BFS-optimal path entering the exit chute via $(2,32) \to (1,32) \to (0,32) \to (0,31)$ on the learned map. Full animations: \texttt  {figures/beta\_demo\_exploration.gif} and \texttt  {figures/beta\_demo\_converged.gif}.}}{10}{figure.caption.12}\protected@file@percent }
\newlabel{fig:beta-strip}{{7}{10}{Visual progression on maze-beta (no training). \emph {Top row:} episode~1 --- 5203 turns, 49 deaths spent discovering the V-fire rotations and the single-entry chute to the exit. \emph {Bottom row:} converged episode~3 --- the agent runs the 80-turn BFS-optimal path entering the exit chute via $(2,32) \to (1,32) \to (0,32) \to (0,31)$ on the learned map. Full animations: \texttt {figures/beta\_demo\_exploration.gif} and \texttt {figures/beta\_demo\_converged.gif}}{figure.caption.12}{}}
