\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Left: maze-alpha walls + hazards. Right: agent's trajectory on a successful evaluation episode. The agent's path (crimson) is the BFS-shortest route after the map has been learned from episode 1.}}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:alpha}{{1}{5}{Left: maze-alpha walls + hazards. Right: agent's trajectory on a successful evaluation episode. The agent's path (crimson) is the BFS-shortest route after the map has been learned from episode 1}{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Learning curve on maze-alpha: turns-to-goal drops from 4729 in episode 1 (exploration) to a steady 87 in episodes 2--5 (exploitation of the learned map).}}{6}{figure.caption.6}\protected@file@percent }
\newlabel{fig:learning}{{2}{6}{Learning curve on maze-alpha: turns-to-goal drops from 4729 in episode 1 (exploration) to a steady 87 in episodes 2--5 (exploitation of the learned map)}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Exploration heatmap on maze-alpha: warmer cells were visited more often. After the map is learned, traffic concentrates on the shortest known path.}}{6}{figure.caption.7}\protected@file@percent }
\newlabel{fig:heatmap}{{3}{6}{Exploration heatmap on maze-alpha: warmer cells were visited more often. After the map is learned, traffic concentrates on the shortest known path}{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Visual progression on maze-alpha. \emph  {Top row:} episode~1 --- the agent (blue dot) explores blindly, dying on unseen V-fire cells and accumulating a crimson trail of every cell visited. \emph  {Bottom row:} converged episode~2 --- with the edge map and per-phase fire sets learned, the strict BFS produces a clean 87-turn path straight to the goal (red star). Full animations: \texttt  {figures/alpha\_demo\_exploration.gif} and \texttt  {figures/alpha\_demo\_converged.gif}.}}{7}{figure.caption.8}\protected@file@percent }
\newlabel{fig:alpha-strip}{{4}{7}{Visual progression on maze-alpha. \emph {Top row:} episode~1 --- the agent (blue dot) explores blindly, dying on unseen V-fire cells and accumulating a crimson trail of every cell visited. \emph {Bottom row:} converged episode~2 --- with the edge map and per-phase fire sets learned, the strict BFS produces a clean 87-turn path straight to the goal (red star). Full animations: \texttt {figures/alpha\_demo\_exploration.gif} and \texttt {figures/alpha\_demo\_converged.gif}}{figure.caption.8}{}}
